/* ============================================================
   VEDICURJA LUXURY UI – 3D CARDS, ANIMATIONS, GRADIENTS
   Mobile‑first, performance‑optimized
   ============================================================ */

/* ----- Ambient Gradient Background (looping) ----- */
.vedic-ambient-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background: linear-gradient(135deg, #FF9933, #C10000, #E8B960, #1A2A3A, #FDFBF7);
  background-size: 400% 400%;
  animation: sacredShift 20s ease infinite;
  mix-blend-mode: overlay;
  opacity: 0.12;
}
@keyframes sacredShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ----- Isometric Social Buttons (Footer) ----- */
.iso-pro {
  position: relative;
  cursor: pointer;
  transition: 0.3s;
  width: 60px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.iso-pro span {
  opacity: 0;
  position: absolute;
  border-radius: 50%;
  transition: all 0.3s;
  height: 60px;
  width: 60px;
  box-shadow: inset 0 0 20px rgba(255,255,255,0.3), inset 0 0 5px rgba(255,255,255,0.5), 0 5px 5px rgba(0,0,0,0.164);
  border: 1px solid rgba(232,185,96,0.3);
}
.iso-pro:hover span { opacity: 1; }
.iso-pro:hover span:nth-child(1) { opacity: 0.2; }
.iso-pro:hover span:nth-child(2) { opacity: 0.4; transform: translate(5px, -5px); }
.iso-pro:hover span:nth-child(3) { opacity: 0.6; transform: translate(10px, -10px); }
.iso-pro .svg {
  transition: all 0.3s;
  padding: 1rem;
  height: 60px;
  width: 60px;
  border-radius: 50%;
  color: #E8B960;
  fill: currentColor;
  box-shadow: inset 0 0 20px rgba(255,255,255,0.3), inset 0 0 5px rgba(255,255,255,0.5), 0 5px 5px rgba(0,0,0,0.164);
  background: rgba(26,42,58,0.6);
  backdrop-filter: blur(4px);
}
.iso-pro:hover .svg {
  transform: translate(15px, -15px);
  color: #FF9933;
}
.iso-pro .text {
  opacity: 0;
  border-radius: 5px;
  padding: 5px 10px;
  transition: all 0.3s;
  color: #FF9933;
  background: rgba(255,255,255,0.2);
  backdrop-filter: blur(4px);
  position: absolute;
  z-index: 10;
  box-shadow: -5px 0 1px rgba(0,0,0,0.1), inset 0 0 20px rgba(255,255,255,0.3);
  font-size: 12px;
  white-space: nowrap;
  pointer-events: none;
}
.iso-pro:hover .text {
  opacity: 1;
  transform: translate(25px, -2px) skew(-5deg);
}

/* ----- Animated Stat Card (Free Tools) ----- */
.stat-card {
  min-height: 24em;
  min-width: 18em;
  border-radius: 1.5em;
  background: linear-gradient(145deg, #FFFACD 0%, #FFF599 100%);
  padding: 0.5rem;
  font-family: var(--font-montserrat), sans-serif;
  color: #B49A18;
  box-shadow: 0 25px 35px -12px rgba(26,42,58,0.2), 0 0 0 1px rgba(232,185,96,0.3) inset;
  transition: transform 0.3s;
}
.stat-card:hover { transform: translateY(-5px); }
.stat-card .stat-header {
  display: flex;
  height: 4em;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,245,153,0.5);
  border-radius: 1.5em;
  padding: 0.5rem;
  backdrop-filter: blur(4px);
}
.stat-card .stat-value {
  font-size: 2rem;
  font-weight: 800;
  color: #1A2A3A;
}
.stat-card .stat-label {
  font-size: 1rem;
  opacity: 0.8;
}
.stat-card .progress-ring {
  width: 10em;
  height: 10em;
}

/* ----- Testimonial Card (Gradient Border) ----- */
.testimonial-luxury-card {
  position: relative;
  width: 190px;
  height: 254px;
  background: #1A2A3A;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 12px;
  gap: 12px;
  border-radius: 15px;
  cursor: pointer;
  color: white;
  transition: transform 0.3s;
}
.testimonial-luxury-card::before {
  content: "";
  position: absolute;
  inset: 0;
  left: -5px;
  margin: auto;
  width: 200px;
  height: 264px;
  border-radius: 15px;
  background: linear-gradient(-45deg, #FF9933 0%, #C10000 50%, #E8B960 100%);
  z-index: -10;
  pointer-events: none;
  transition: all 0.6s cubic-bezier(0.175,0.885,0.32,1.275);
}
.testimonial-luxury-card::after {
  content: "";
  z-index: -1;
  position: absolute;
  inset: 0;
  background: linear-gradient(-45deg, #E8B960 0%, #FF9933 100%);
  transform: translate3d(0,0,0) scale(0.95);
  filter: blur(40px);
}
.testimonial-luxury-card:hover::before {
  transform: rotate(-90deg) scaleX(1.34) scaleY(0.77);
}
.testimonial-luxury-card:hover::after {
  filter: blur(50px);
}
.testimonial-luxury-card .heading {
  font-size: 20px;
  text-transform: uppercase;
  font-weight: 800;
  color: #E8B960;
}
.testimonial-luxury-card .content-text {
  font-size: 14px;
  color: #FDFBF7;
  line-height: 1.4;
}
.testimonial-luxury-card .location {
  font-size: 12px;
  color: #E8B960;
}

/* ----- 3D Service Card (Glassmorphism) ----- */
.service-3d-parent {
  width: 290px;
  height: 300px;
  perspective: 1000px;
  position: relative;
}
.service-3d-card {
  height: 100%;
  border-radius: 50px;
  background: linear-gradient(135deg, #FF9933 0%, #C10000 50%, #E8B960 100%);
  transition: all 0.5s ease-in-out;
  transform-style: preserve-3d;
  box-shadow: rgba(37,5,71,0) 40px 50px 25px -40px, rgba(34,5,71,0.2) 0px 25px 25px -5px;
  position: relative;
}
.service-3d-glass {
  transform-style: preserve-3d;
  position: absolute;
  inset: 8px;
  border-radius: 55px;
  border-top-right-radius: 100%;
  background: linear-gradient(0deg, rgba(255,255,255,0.35) 0%, rgba(255,255,255,0.8) 100%);
  backdrop-filter: blur(5px);
  transform: translate3d(0,0,25px);
  border-left: 1px solid white;
  border-bottom: 1px solid white;
  transition: all 0.5s ease-in-out;
}
.service-3d-content {
  padding: 100px 60px 0 30px;
  transform: translate3d(0,0,26px);
  position: relative;
  z-index: 10;
}
.service-3d-title {
  color: white;
  font-weight: 900;
  font-size: 20px;
}
.service-3d-text {
  color: rgba(255,255,255,0.9);
  font-size: 15px;
  margin-top: 20px;
}
.service-3d-bottom {
  padding: 10px 12px;
  transform-style: preserve-3d;
  position: absolute;
  bottom: 20px;
  left: 20px;
  right: 20px;
  transform: translate3d(0,0,26px);
  z-index: 10;
}
.service-3d-parent:hover .service-3d-card {
  transform: rotate3d(1,1,0,30deg);
  box-shadow: rgba(28,5,71,0.3) 30px 50px 25px -40px, rgba(28,5,71,0.3) 0px 25px 30px 0px;
}
@media (max-width: 640px) {
  .service-3d-parent { width: 250px; height: 280px; }
  .service-3d-content { padding: 80px 40px 0 20px; }
  .service-3d-title { font-size: 18px; }
  .service-3d-text { font-size: 13px; margin-top: 15px; }
}

/* ----- Sun Globe (Global Presence) ----- */
.section-banner-sun {
  height: 300px;
  width: 300px;
  position: relative;
  border-radius: 50%;
  background: url("/images/home/globe-texture.jpg") center/cover;
  animation: sunRotate 30s linear infinite, shadowPulse 5s ease-in-out infinite;
  box-shadow: 0 0 40px 20px rgba(255,140,0,0.8);
}
.om-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 6rem;
  color: #FF9933;
  text-shadow: 0 0 30px #C10000;
  z-index: 5;
  pointer-events: none;
}
@keyframes sunRotate { 100% { background-position: 400px 0; } }
@keyframes shadowPulse { 50% { box-shadow: 0 0 60px 30px rgba(255,140,0,0.9); } }

/* ----- Social Connect Card ----- */
.connect-card {
  width: 250px;
  transition: 0.15s all ease-in-out;
  border-radius: 10px;
  padding: 5px;
  border: 4px solid transparent;
  cursor: pointer;
  background: white;
}
.connect-card:hover {
  box-shadow: 10px 10px 0 #FF9933, 20px 20px 0 #C10000;
  border-color: #E8B960;
  transform: translate(-20px, -20px);
}
.connect-card .card-image {
  width: 100%;
  height: 170px;
  background: linear-gradient(145deg, #FF9933, #C10000);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
}
.connect-card .project-title {
  font-size: 1.8em;
  font-weight: 600;
  color: #1A2A3A;
}
.connect-card .project-type {
  background: #FF9933;
  color: white;
  padding: 0.3em 0.7em;
  border-radius: 15px;
  font-size: 12px;
}

/* ----- Om Sound Widget (Compact) ----- */
.om-sound-widget {
  position: fixed;
  bottom: 20px;
  left: 20px;
  z-index: 50;
  transform: scale(0.7);
  transform-origin: bottom left;
}
@media (max-width: 640px) {
  .om-sound-widget { transform: scale(0.5); }
  .testimonial-luxury-card { width: 160px; height: 220px; }
  .connect-card { width: 200px; }
}

/* Additional animations */
@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes reverse-spin {
  from { transform: rotate(360deg); }
  to { transform: rotate(0deg); }
}
.animate-spin-slow {
  animation: spin-slow 8s linear infinite;
}
.animate-reverse-spin {
  animation: reverse-spin 10s linear infinite;
}

/* Footer Social Icons - Smaller & Color Fix */
.footer .iso-pro {
  width: 44px !important;
  height: 44px !important;
}
.footer .iso-pro .svg {
  height: 44px !important;
  width: 44px !important;
  padding: 10px !important;
  color: #E8B960 !important;
  background: rgba(26, 42, 58, 0.7) !important;
  backdrop-filter: blur(4px);
}
.footer .iso-pro:hover .svg {
  color: #FF9933 !important;
  background: rgba(26, 42, 58, 0.9) !important;
}
.footer .iso-pro span {
  height: 44px !important;
  width: 44px !important;
}
.footer .iso-pro .text {
  font-size: 11px !important;
  background: rgba(26, 42, 58, 0.8) !important;
  color: #E8B960 !important;
}

/* Mouse tracking glow effect */
.group:hover .mouse-glow {
  opacity: 1;
}

@keyframes gradient-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}
.animate-gradient-shift {
  background-size: 200% 200%;
  animation: gradient-shift 8s ease infinite;
}
  to { opacity: 1; transform: translateY(0); }
}
  animation: fadeIn 0.6s ease-out forwards;
}
