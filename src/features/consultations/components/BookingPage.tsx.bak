// ----------------------------------------------------------------------
// Pricing Section – Single ₹10,000 Plan
// ----------------------------------------------------------------------
function PricingSection({ onSelect, selectedPrice }: { onSelect: (price:number) => void; selectedPrice: number | null }) {
  return (
    <section className="py-24 bg-white">
      <div className="container mx-auto px-4 max-w-md">
        <AnimatedText text="Simple Pricing" className="font-serif text-4xl text-center text-nidra-indigo mb-4" />
        <p className="text-center text-nidra-indigo/60 mb-12">One comprehensive package for your transformation</p>
        <div className="relative p-8 rounded-2xl border-2 border-prakash-gold shadow-xl bg-white text-center">
          <span className="absolute -top-3 left-1/2 -translate-x-1/2 bg-sacred-saffron text-white px-4 py-1 rounded-full text-xs">Premium Annual</span>
          <h3 className="font-serif text-2xl mb-2 mt-2">Complete Vastu Guidance</h3>
          <p className="text-4xl font-bold text-nidra-indigo mb-4">₹10,000</p>
          <p className="text-sm text-nidra-indigo/60 mb-6">Unlimited sessions for one year</p>
          <button 
            onClick={() => onSelect(10000)} 
            className={`w-full py-3 rounded-full text-lg font-medium transition ${selectedPrice === 10000 ? 'bg-prakash-gold text-white' : 'border-2 border-prakash-gold text-prakash-gold hover:bg-prakash-gold/10'}`}
          >
